{
	"include": ["src/**/*"],
	"exclude": ["node_modules"],
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"strict": false,
		"noImplicitAny": false,
		"strictNullChecks": false,
		"useUnknownInCatchVariables": false,
		"allowImportingTsExtensions": true,
		"types": ["@scenery/cavalry-types"],
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true
	}
}
